<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrashTrack - Pelaporan Sampah Liar</title>
    <!-- Bootstrap 5 CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .img-laporan { width: 100px; height: 100px; object-fit: cover; border-radius: 8px; }
    </style>
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4 shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">♻️ TrashTrack</a>
    </div>
</nav>

<div class="container">
    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="row">
        <!-- Kolom Form Pelaporan (Masyarakat) -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="card-title fw-bold text-success">Lapor Sampah Liar</h5>
                </div>
                <div class="card-body">
                    <form action="/lapor" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="lokasi" class="form-label text-muted small fw-bold">LOKASI SAMPAH</label>
                            <input type="text" class="form-control" id="lokasi" name="lokasi" required placeholder="Cth: Jl. Merdeka No. 1, Samping sungai...">
                        </div>
                        <div class="mb-3">
                            <label for="deskripsi" class="form-label text-muted small fw-bold">DESKRIPSI</label>
                            <textarea class="form-control" id="deskripsi" name="deskripsi" rows="3" required placeholder="Jelaskan kondisi tumpukan sampah..."></textarea>
                        </div>
                        <div class="mb-4">
                            <label for="foto" class="form-label text-muted small fw-bold">FOTO BUKTI (WAJIB)</label>
                            <input type="file" class="form-control" id="foto" name="foto" accept="image/*" required>
                        </div>
                        <button type="submit" class="btn btn-success w-100 fw-bold">Kirim Laporan</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Kolom Daftar Laporan (Dashboard/Petugas Admin) -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="card-title fw-bold text-secondary">Daftar Laporan Masyarakat</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Foto</th>
                                    <th>Detail Laporan</th>
                                    <th>Status</th>
                                    <th>Aksi Petugas</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (laporan && laporan.length > 0) { %>
                                    <% laporan.forEach(item => { %>
                                        <tr>
                                            <td class="text-muted fw-bold">#<%= item.id %></td>
                                            <td>
                                                <a href="<%= item.foto_url %>" target="_blank">
                                                    <img src="<%= item.foto_url %>" alt="Foto Laporan" class="img-laporan shadow-sm">
                                                </a>
                                            </td>
                                            <td>
                                                <strong><%= item.lokasi %></strong><br>
                                                <span class="text-muted small"><%= item.deskripsi %></span>
                                            </td>
                                            <td>
                                                <% if (item.status === 'Menunggu') { %>
                                                    <span class="badge bg-warning text-dark">Menunggu</span>
                                                <% } else if (item.status === 'Dikerjakan') { %>
                                                    <span class="badge bg-primary">Dikerjakan</span>
                                                <% } else if (item.status === 'Diangkut') { %>
                                                    <span class="badge bg-success">Diangkut</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <form action="/update-status/<%= item.id %>" method="POST" class="d-flex gx-2">
                                                    <select name="status" class="form-select form-select-sm me-2" style="width: auto;">
                                                        <option value="Menunggu" <%= item.status === 'Menunggu' ? 'selected' : '' %>>Menunggu</option>
                                                        <option value="Dikerjakan" <%= item.status === 'Dikerjakan' ? 'selected' : '' %>>Dikerjakan</option>
                                                        <option value="Diangkut" <%= item.status === 'Diangkut' ? 'selected' : '' %>>Diangkut</option>
                                                    </select>
                                                    <button type="submit" class="btn btn-sm btn-outline-success">Update</button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted"> Belum ada laporan sampah masuk.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>